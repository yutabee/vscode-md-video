{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "types": ["node"],
    "outDir": "out-test",
    "rootDir": ".",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/transform.ts", "src/media/audio.ts", "src/media/mediaFormat.ts", "test", "test-support"],
  "exclude": ["node_modules", "out", "out-test", "dist", "src/webview"]
}
